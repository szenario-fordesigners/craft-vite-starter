{
	"name": "craft-vite-starter",
	"version": "2.4.3",
	"description": "Craft CMS 5 + DDEV + Vite Blueprint",
	"type": "module",
	"scripts": {
		"predev": "rimraf ./web/dist && node viteDevServerToggle.js 1",
		"dev": " vite --host",
		"prebuild": "node viteDevServerToggle.js 0 && tsc",
		"build": "vite build",
		"type-check": "tsc --noEmit",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/szenario-fordesigners/craft-vite-starter/.git"
	},
	"author": "@szenario-fordesigners, @smonist, @thomasbendl",
	"license": "0BSD",
	"engines": {
		"node": ">=24.0.0"
	},
	"bugs": {
		"url": "https://github.com/szenario-fordesigners/craft-vite-starter/issues"
	},
	"homepage": "https://github.com/szenario-fordesigners/craft-vite-starter/#readme",
	"devDependencies": {
		"@types/node": "24.13.2",
		"@tailwindcss/vite": "4.3.2",
		"@zackad/prettier-plugin-twig": "0.17.0",
		"prettier": "3.9.4",
		"regenerator-runtime": "0.14.1",
		"rimraf": "6.1.3",
		"rollup-plugin-critical": "1.0.16",
		"sass-embedded": "1.100.0",
		"tailwindcss": "4.3.2",
		"terser": "5.48.0",
		"typescript": "6.0.3",
		"vite": "8.1.0",
		"vite-plugin-compression": "0.5.1",
		"vite-plugin-live-reload": "3.1.0",
		"@vitejs/plugin-legacy": "8.1.0"
	},
	"dependencies": {}
}
